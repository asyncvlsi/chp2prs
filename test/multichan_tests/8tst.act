import "8decomp.act";

defproc test ()
{
    chan(int) X1, Y1, Y2;
    decomp_mc8 m(X1, Y1, Y2);

    int y0;
    int y1,y2,y3,y4;

    chp {
        (X1!3) , 
        (Y1?y0) , 
        (Y2?y1 ; Y2?y2 ; Y2?y3 ; Y2?y4) ;
        [ y0=0 & y1=3 & y2=2 & y3=1 & y4=0 -> log ("SUCCESS") 
        [] else -> log ("FAILURE") 
        ]
    }
}

