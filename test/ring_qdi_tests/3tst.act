import globals;
import "3.act";
import "3_ring.act";

defproc test()
{
  ring_testproc t;
  bool at[8], af[8], aa;
  at = t.Y.d.t;
  af = t.Y.d.f;
  aa = t.Y.a;
  chp {
      // a = 25
      [at[0]=true  & af[0]=false & 
       at[1]=false & af[1]=true  & 
       at[2]=false & af[2]=true  & 
       at[3]=true  & af[3]=false & 
       at[4]=true  & af[4]=false & 
       at[5]=false & af[5]=true  & 
       at[6]=false & af[6]=true  & 
       at[7]=false & af[7]=true  & 
       aa=true
      -> log("SUCCESS")]
  }
}
