import globals;
import "2.act";
import "2_ring.act";

defproc test()
{
  pint W = 4;
  ring_testproc t;
  bool at[W], af[W], aa;
  at = t.Y.d.t;
  af = t.Y.d.f;
  aa = t.Y.a;
  chp {
      // a = 10
      [at[0]=false & af[0]=true  & 
       at[1]=true  & af[1]=false & 
       at[2]=false & af[2]=true  & 
       at[3]=true  & af[3]=false & 
       aa=true 
        -> log("SUCCESS")]
  }
}
