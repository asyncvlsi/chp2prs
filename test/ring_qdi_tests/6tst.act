defproc test()
{
  ring_testproc t;
  bool at[8], af[8], aa;
  at = t.Y.d.t;
  af = t.Y.d.f;
  aa = t.Y.a;
  chp {
      // a = 55
      [
      at[0]=true  & 
      at[1]=true  & 
      at[2]=true  & 
      at[3]=false & 
      at[4]=true  &
      at[5]=true  &
      at[6]=false &
      at[7]=false &

      af[0]=false & 
      af[1]=false & 
      af[2]=false & 
      af[3]=true  & 
      af[4]=false &
      af[5]=false &
      af[6]=true  &
      af[7]=true  &

      aa = true
      -> log("SUCCESS")]
  }
}
