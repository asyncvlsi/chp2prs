
defproc prober (chan?(int<8>) l1, l2, l3; chan!(int<8>) r)
{
	int<8> x;
	chp{
        *[
            [| #l1 -> l1?x
            [] #l2 -> l2?x
            [] #l3 -> l3?x
            |];
            r!x
        ]
	}
}

defproc src5 (chan!(int<8>) r)
{
	chp{
		*[r!5]
	}
}

defproc src2 (chan!(int<8>) r)
{
	chp{
		*[r!2]
	}
}

defproc src8 (chan!(int<8>) r)
{
	chp{
		*[r!8]
	}
}

defproc snk (chan?(int<8>) l)
{
	int<8> x;
	chp{
		*[l?x; log("%d", x)]
	}
}

defproc testproc (chan?(int<8>) X1, X2, X3; chan!(int<8>) Y)
{
  prober p(X1,X2,X3,Y);

  src5  ix1(X1);
  src2  ix2(X2);
  src8  ix3(X3);

  snk o(Y);
}
