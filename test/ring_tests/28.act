
template<pint W>
deftype kstr (
    int<W> x;
    int<W> y
){}

defproc src (chan!(kstr<4>) C)
{
    kstr<4> k;
    chp {
        *[ k := kstr<4>(2); C!k ]
    }
}

defproc snk (chan?(kstr<4>) C)
{
    kstr<4> x;
    chp {
        *[ C?x; log("x : ", x.x); log("y : ",x.y) ]
    }
}

defproc kbuf (chan?(kstr<4>) L; chan!(kstr<4>) R)
{
    kstr<4> k;
    chp {
        *[ L?k; k.x:=1; R!k ]
    }
}

defproc testproc(chan!(kstr<4>) Y)
{
    kbuf b;
    snk sn(b.R);
    src sr(b.L);
	Y = b.R;
}