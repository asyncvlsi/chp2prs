
defproc gcd (chan?(int<8>) l1; chan?(int<8>) l2; chan!(int<8>) r1)
{
	int<8> x,y;
	chp {
		*[
			l1?x; l2?y;
			*[ x>y -> x:=x-y
			[] y>x -> y:=y-x
			];
			r1!x
		]
	}
}

defproc source_100 (chan!(int<8>) c)
{
	chp{
		*[c!100]
	}
}

defproc source_15 (chan!(int<8>) c)
{
	chp{
		*[c!15]
	}
}

defproc snk (chan?(int<8>) l)
{
	int<8> x;
	chp{
		*[l?x; log("%d", x)]
	}
}

defproc testproc (chan?(int<8>) X1, X2; chan!(int<8>) Y)
{
  gcd g(X1, X2, Y);

  source_100 ix1(X1);
  
  source_15 ix2(X2);

  snk o(Y);
}
