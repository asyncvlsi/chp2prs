import "11decomp.act";

defproc test ()
{
    chan(int) Y;
    decomp_dc11 m(Y);

    int y0, y1, y2, y3;

    chp {
        (Y?y0 ; Y?y1 ; Y?y2 ; Y?y3);
        [ y0=1  & 
          y1=512  & 
          y2=262144 & 
          y3=134217728 -> log ("SUCCESS") 
        [] else -> log ("FAILURE") 
        ]
    }
}

