// Bundled Data Datapath

namespace syn {
  
  export namespace ring_2phase {
    

// Variables and Channels ---------------------------------

export template <pint M>
deftype ring_int <: int<M> (bool d[M]) {} 

export deftype ring_bool <: bool (bool d[1]) {} 

export defchan ring_chan <: bd () {}

// --------------------------------------------------------

export defproc ram_builtin <: std::ram () 
+{
  ring_chan<std::ceil_log2(N)> addr;
  ring_chan<2> rd;
  ring_chan<W> dout;
  ring_chan<W> din;
}{
  { 42=42 : "placeholder" };
  // TODO: bundled data 2-phase memory compiler circuit needs to go here
}

// Basic Elements -----------------------------------------

defproc inverter (bool? in; bool! out)
{
    prs *{
        in => out-
    }
    sizing { 
        out{-1} 
    }
}

export defproc sink_brs (a1of1 c)
{
  bool x;
  prs *{
      c.r => x-
      x   => c.a-
  }
  sizing { x{-1}; c.a{-1} }
}

export defproc source_brs (a1of1 c)
{
  prs *{
        ~c.a => c.r+
  }
  sizing { c.r{-1} }
}

