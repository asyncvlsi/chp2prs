// Control Elements ---------------------------------------

// The Two Main Pipe Elements ---------

export defproc asym_c_brs (bool? A, B, C; bool! Y)
{
    prs * {
        ~Reset & ( ~A & ~B & ~C ) -> Y+
         Reset | (       B &  C ) -> Y- 
    }
}

/*
export defproc elem_c_paa_send (a1of1 m1; a1of1 zero; a1of1 p1)
{
    inverter im1r, izeroa;
    im1r.in = m1.r;
    izeroa.in = zero.a;

    asym_c_brs ac;
    ac.A = im1r.out;
    ac.B = zero.a;
    ac.C = m1.a;
    ac.Y = zero.r;

    m1.a = p1.r;

    prs * {
        ~Reset & ( ~im1r.out & ~izeroa.out & ~p1.a ) -> m1.a+
         Reset | (  im1r.out &  izeroa.out &  p1.a ) -> m1.a-
    }
}
*/

export defproc elem_c_paa_send (a1of1 m1; a1of1 zero; a1of1 p1)
{

  bool _m1_r;
  inverter m1_inv(m1.r,_m1_r);

  zero.a = p1.r;
  zero.r = m1.a;

  prs * {
      ~Reset & (~_m1_r & ~zero.a & ~p1.a) -> zero.r+ 
        Reset | (_m1_r &  zero.a &  p1.a) -> zero.r-
  }
  sizing { 
      zero.r{-1} 
  }
  spec {
    timing _m1_r- -> zero.r+
    timing zero.a- -> zero.r+
    timing p1.a- -> zero.r+
    timing _m1_r+ -> zero.r-
    timing zero.a+ -> zero.r-
    timing p1.a+ -> zero.r-
  }
}

export defproc elem_c_paa (a1of1 m1; a1of1 zero; a1of1 p1)
{
  m1.r = zero.r;
  zero.a = p1.r;
  p1.a = m1.a;
}

export defproc elem_c_paa_c_t (a1of1 m1; a1of1 zero; a1of1 p1)
{

  bool _m1_r;
  inverter m1_inv(m1.r,_m1_r);

  zero.a = p1.r;
  zero.r = m1.a;

  prs * {
      ~Reset & (~_m1_r & ~zero.a & ~p1.a) -> zero.r+ 
        Reset | (_m1_r &  zero.a &  p1.a) -> zero.r-
  }
  sizing { 
      zero.r{-1} 
  }
  spec {
    timing _m1_r- -> zero.r+
    timing zero.a- -> zero.r+
    timing p1.a- -> zero.r+
    timing _m1_r+ -> zero.r-
    timing zero.a+ -> zero.r-
    timing p1.a+ -> zero.r-
  }
}

export template<pint N>
defproc elem_c_paa_c (a1of1 m1; a1of1 zero[N]; a1of1 p1)
{
  elem_c_paa_c_t c_t;
  c_t.m1 = m1;
  c_t.p1 = p1;

  std::gates::sigbuf<N> s;
  std::gates::ctree<N, false> c;

  s.in = c_t.zero.r;
  ( i : N : s.out[i] = zero[i].r; )

  c.out = c_t.zero.a;
  ( i : N : c.in[i] = zero[i].a; )
}

/*
export defproc elem_c_ppa (a1of1 m1; a1of1 data; a1of1 zero; a1of1 p1)
{
  bool _m1_r, _zero_r;
  inverter m1_inv(m1.r,_m1_r);
  inverter zr_inv(zero.r,_zero_r);

  asym_c_brs ac;
  ac.A = _m1_r;
  ac.B = _zero_r;
  ac.C = m1.a;
  ac.Y = data.r;

  bool _data_a;
  inverter da_inv(data.a,_data_a);
  data.a = zero.a;
  
  m1.a = p1.r;

  prs * {
      ~Reset & (~_m1_r &  ~_data_a & ~p1.a) -> p1.r+ 
        Reset | (_m1_r &   _data_a &  p1.a) -> p1.r-
  }
  sizing { 
      p1.r{-1} 
  }
}
*/

export defproc elem_c_ppa (a1of1 m1; a1of1 data; a1of1 zero; a1of1 p1)
{

  bool _zero_r, _m1_r;
  inverter zero_inv(zero.r,_zero_r);
  inverter m1_inv(m1.r,_m1_r);

  zero.a = p1.r;
  data.a = zero.a;
  data.r = m1.a;

  prs * {
      ~Reset & (~_m1_r &  ~_zero_r & ~p1.a) -> data.r+ 
        Reset | (_m1_r &   _zero_r &  p1.a) -> data.r-
  }
  sizing { 
      data.r{-1} 
  }
  spec {
    timing _m1_r- -> data.r+
    timing p1.a+ -> data.r-
    // timing da_inv.in- -> da_inv.out+
    // timing da_inv.in+ -> da_inv.out-
    timing zero_inv.in- -> zero_inv.out+
    timing zero_inv.in+ -> zero_inv.out-
    timing m1_inv.in- -> m1_inv.out+
    timing m1_inv.in+ -> m1_inv.out-
  }
}

// ------------------------------------

// Skip element -----------------------

export defproc elem_c_skip (a1of1 m1; a1of1 p1)
{
    m1 = p1;
}
// ------------------------------------


// Pause element ----------------------

export defproc elem_c_pause (a1of1 m1; a1of1 pause; a1of1 p1)
{
  bool _m1_r;
  inverter m1_inv(m1.r,_m1_r);

  bool u, _u, v;
  std::ideal_arbiter ia(pause.r, m1.a, u, p1.r);
  inverter pause_inv(u,_u);

  std::cells::NOR2X1 and1(_m1_r, _u, pause.a);

  prs * {
      ~Reset & (~_m1_r & ~p1.r & ~p1.a) -> m1.a+ 
        Reset | (_m1_r &  p1.r &  p1.a) -> m1.a-
  }
  sizing { 
      m1.a{-1} 
  }
}
// ------------------------------------


// Initial token buffer ---------------

export defproc elem_c_itb (a1of1 m1; a1of1 p1)
{
    prs * {
        ~Reset & (~m1.r & ~p1.a) -> p1.r+
         Reset | ( m1.r &  p1.a) -> p1.r-
    }

    inverter m1_inv(p1.r,m1.a);
}

// ------------------------------------


// N-way parallelizer -----------------
// for comma-separated statements

export template<pint N>
defproc parallel_split(a1of1? m1; a1of1 co[N]) 
{
    std::gates::sigbuf<N> s(m1.r);
    ( i : N: s.out[i] = co[i].r; )

    std::gates::ctree<N, false> ct(, m1.a);
    ( i : N: ct.in[i] = co[i].a; )
}

export template<pint N>
defproc parallel_merge(a1of1 ci[N]; a1of1! p1) 
{
    std::gates::ctree<N, false> ct(, p1.r);
    ( i : N: ct.in[i] = ci[i].r; )

    std::gates::sigbuf<N> s(p1.a);
    ( i : N: s.out[i] = ci[i].a; )
}
// ------------------------------------


// N-way selection split & merge ------
// for selections

export template<pint N>
defproc selection_split(bool? gs[N]; a1of1? m1; a1of1 co[N]) 
{
    capture_init<R2P_SEL_SPLIT_CD, R2P_SEL_SPLIT_PW, 1, 0> capt1[N], capt2[N];
    std::cells::XOR2X1 xors[N];

    ( i : N: capt1[i].go.r = m1.r; )
    ( i : N: xors[i].A = co[i].a; )
    ( i : N: xors[i].B = gs[i]; )
    ( i : N: xors[i].Y = capt1[i].din[0]; )
    // ( i : N: capt1[i].dout[0] = co[i].r; )

    ( i : N: capt2[i].dout[0] = co[i].r; )
    ( i : N: capt2[i].din[0] = capt1[i].dout[0]; )
    ( i : N: capt2[i].go.r = capt1[i].go.a; )

    std::gates::xortree<N, false> ort(, m1.a);
    ( i : N: ort.in[i] = co[i].a; )

    ( i : N :
    spec {
       timing gs[i] : xors[i].Y < m1.r
    } )
}

export template<pint N>
defproc selection_merge(a1of1 ci[N]; a1of1! p1) 
{
    std::gates::xortree<N, false> xort;
    ( i : N: xort.in[i] = ci[i].r; )
    delay_line<R2P_SEL_MERGE_XOR_DELAY> delay_xor;
    delay_xor.in = xort.out;
    delay_xor.out = p1.r;

    // std::gates::sigbuf<N> s(p1.a);
    // ( i : N: s.out[i] = ci[i].a; )

    capture_init<R2P_SEL_MERGE_CD, R2P_SEL_MERGE_PW, 1, 0> capt1[N], capt2[N];

    ( i : N: capt1[i].go.r = p1.a; )
    ( i : N: capt1[i].din[0] = ci[i].r; )
    ( i : N: capt2[i].din[0] = capt1[i].dout[0]; )
    ( i : N: capt2[i].dout[0] = ci[i].a; )
    ( i : N: capt2[i].go.r = capt1[i].go.a; )

    // this is trivially true but i'll leave it in
    ( i : N :
    spec {
       timing ci[i].r : capt1[i].din[0] < p1.r
    } )
}
// ------------------------------------


// N-way non-deterministic split ------

defproc c1 (bool ctrl, ka, a, out)
{
    bool _out;
    prs * {
        [after=0] a & ctrl -> _out-
        [after=0] ~ka & ~ctrl -> _out+
        [after=0] _out => out-
    }
}

defproc c2 (bool A, B, ack, out)
{
    bool _out;
    prs * {
        // ack -> _out-
        // ~ack & ~A & ~B -> _out+
        // _out => out-
        [after=0] ack -> _out-
        [after=0] ~ack & ~A & ~B -> _out+
        [after=0] _out => out-
    }
}

export defcell killable_arbiter(bool? a, b, _ki; bool! u, v, _ka) 
{
  bool _u, _v;
  bool _Reset;

  /* force exclusive low signals for simulation */
  spec {
    mk_excllo(_u,_v)
  }
  
  bool ka;

  prs * {
    // inverted Reset to initialize correctly
    Reset => _Reset-
    /* cross coupled nand gates, with kill tail NMOS */
    [keeper=0] _ki & a & _v -> _u-
    [keeper=0] ~_ki | ~a | ~_v | ~_Reset -> _u+
    [keeper=0] _ki & b & _u -> _v-
    [keeper=0] ~_ki | ~b | ~_u | ~_Reset -> _v+

   /* output filter */
    [keeper=0] _u<5> -> u-
    [keeper=0] _v<5> -> v-
    passp<10>(_u,_v,u)
    passp<10>(_v,_u,v)

    u | v => ka-
    ka => _ka-

  }
  sizing {
   leak_adjust <- 1;
   _u{-1};
   _v{-1}
  }
}

