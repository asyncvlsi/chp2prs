// Connectors ---------------------------------------------

export defproc gp_connect (a1of1 m1; a1of1 p1)
{
  m1 = p1;
}

export template<pint VW, CW>
defproc connect_chan_to_capture (bool v[VW]; bool c[CW])
{
  pint MW = (CW<VW) ? CW : VW;
  ( i : MW : c[i] = v[i]; )
}

export template<pint W>
defproc connect_inchan_to_ctrl (ring_chan<W> ch; a1of1 ctrl)
{
  ch.r = ctrl.r;
  ch.a = ctrl.a;
}

export template<pint W>
defproc connect_capture_din (ring_chan<W> ch; bool d[W])
{
  [ W > 0 -> ch.d = d; ]
}

export template<pint W>
defproc connect_outchan_to_ctrl (ring_chan<W> ch; a1of1 ctrl; bool e[W])
{
  ch.r = ctrl.r;
  ch.a = ctrl.a;
  [ W > 0 -> ch.d = e; ]
}

export template<pint W>
defproc connect_capture_dout (bool fin[W]; bool d[W])
{
  [ W > 0 -> fin = d; ]
}

export template<pint W>
defproc connect_exprblk_dout (bool d[W]; bool e[W])
{
  [ W > 0 -> e = d; ]
}

export template<pint W>
defproc connect_exprblk_assign (bool d[W]; bool e[W]; a1of1 tx)
{
  [ W > 0 -> e = d; ]
}
