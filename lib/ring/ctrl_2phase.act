  co[1].a = or_ack.B;
  c_ack.ack = or_ack.Y;
  c_ack.out = m1.a;

  arb.u = co[0].r;
  arb.v = co[1].r;
}
*/

defproc c3 (bool A, B, _ka, en)
{
  prs * {
    [after=0] A & B -> en-
    [after=0] (~A | ~B) & ~_ka -> en+
  }
}

export template<pint W>
defproc probe_access(ring_chan<W> C; bool dout[1])
{
  pint TYPE=2;
  [ TYPE=1 ->
    killable_arbiter arb;
    arb.a = C.r;
    arb.b = C.a;
    c3 c_ack;
    c_ack.A = arb.a;
    c_ack.B = arb.b;
    c_ack._ka = arb._ka;
    c_ack.en = arb._ki;

    std::cells::XOR2X1 x1(.A=arb.u, .B=arb.v, .Y=dout[0]);
  []TYPE=2 ->
    delay_line<2> delay; delay.in = C.r;
    std::cells::XOR2X1 x1(.A=delay.out, .B=C.a, .Y=dout[0]);
  ]
  // C.r = dout[0];
}

export template<pint W>
defproc probe_access_neg(ring_chan<W> C; bool dout[1])
{
  delay_line<2> delay; delay.in = C.r;
  std::cells::XNOR2X1 x1(.A=delay.out, .B=C.a, .Y=dout[0]);
  // std::cells::XNOR2X1 x1(.A=C.r, .B=C.a, .Y=dout[0]);
  // prs * {
  //   C.r => dout[0]-
  // }
}

// defproc nds_two_way_old (bool gs[2]; a1of1 m1; a1of1 co[2])
// {
//   bool arb_out[2];
//   killable_arbiter arb(.a=gs[0], .b=gs[1], .u=arb_out[0], .v=arb_out[1]);
//   std::cells::INVX1 inv_arb_en(.A=Reset, .Y=arb._ki);
//   bool go;
//   std::cells::LATCHLO latch_lo(.D=m1.r,.Q=go, .CLK=arb._ka, .R=Reset);

//   capture_init<R2P_SEL_SPLIT_CD, R2P_SEL_SPLIT_PW, 1, 0> capt1[2], capt2[2];
//   std::cells::XOR2X1 xors[2];

//   ( i : 2: capt1[i].go.r = go; )
//   ( i : 2: xors[i].A = co[i].a; )
//   ( i : 2: xors[i].B = arb_out[i]; )
//   ( i : 2: xors[i].Y = capt1[i].din[0]; )

//   ( i : 2: capt2[i].dout[0] = co[i].r; )
//   ( i : 2: capt2[i].din[0] = capt1[i].dout[0]; )
//   ( i : 2: capt2[i].go.r = capt1[i].go.a; )

//   std::gates::xortree<2, false> ort(, m1.a);
//   ( i : 2: ort.in[i] = co[i].a; )

//   ( i : 2 :
//   spec {
//       timing gs[i] : xors[i].Y < m1.r
//   } )
// }

defproc nds_two_way (bool gs[2]; a1of1 m1; a1of1 co[2])
{
  bool arb_out[2];
  killable_arbiter arb(.a=gs[0], .b=gs[1], .u=arb_out[0], .v=arb_out[1]);
  bool go;
  std::cells::LATCHLO latch_lo(.D=m1.r,.Q=go, .CLK=arb._ka, .R=Reset);
  delay_line<2> del_go(go);

  capture_init<R2P_SEL_SPLIT_CD, R2P_SEL_SPLIT_PW, 1, 0> capt1[2];
  std::cells::XOR2X1 xors[2];

  ( i : 2 : capt1[i].go.r = del_go.out; )
  ( i : 2 : xors[i].A = co[i].a; )
  ( i : 2 : xors[i].B = arb_out[i]; )
  ( i : 2 : xors[i].Y = capt1[i].din[0]; )
  std::cells::INVX1 inv_arb_ka (.A=arb._ka);
  std::cells::LATCHLO capt2[2];
  ( i : 2 : capt2[i].D = capt1[i].dout[0]; 
            capt2[i].Q = co[i].r; 
            capt2[i].CLK = inv_arb_ka.Y;
            capt2[i].R = Reset; )

  std::gates::ctree<2, false> cc;
  ( i : 2 : cc.in[i] = capt1[i].go.a; )
  std::cells::XOR2X1 xor_ctrl(.A=m1.r, .B=cc.out, .Y=arb._ki);

  std::gates::xortree<2, false> ort(, m1.a);
  ( i : 2: ort.in[i] = co[i].a; )

  ( i : 2 :
  spec {
      timing gs[i] : xors[i].Y < m1.r
  } )
}

// Round-robin non-deterministic split
export template <pint N>
defproc nds_split (bool? gs[N]; a1of1? m1; a1of1 co[N]) 
{
  [ N=1  -> 
  
  co[0].a = m1.a;
  std::cells::LATCHLO latch_lo(.D=m1.r,.Q=co[0].r, .CLK=gs[0], .R=Reset);
  
  []else ->
  // No. of NDS blocks
  pint M = N;

  nds_two_way nds[M];
  // std::cells::INVX1 inv[M];
  std::cells::NOR2X1 nors[M];
  std::cells::XOR2X1 xor1;
  std::cells::TIELOX1 tielo1;
  std::cells::INVX1 inv_loop;
  std::cells::NOR2X1 reset_nor;
  inv_loop.Y = reset_nor.B;
  Reset = reset_nor.A;

  // connect guards and inverted guards
  ( i : M : nds[i].gs[0] = gs[i]; 
              // inv[i].A = gs[i];
              nors[i].A = gs[i];
              nors[i].B = Reset;
              // inv[i].Y = nds[i].gs[1]; )
              nors[i].Y = nds[i].gs[1]; )

  // first one
  xor1.B = m1.r;
  xor1.Y = nds[0].m1.r;
  m1.a = nds[0].m1.a;
 
  ( i : M-1 : nds[i].co[0] = co[i]; 
              nds[i].co[1] = nds[i+1].m1; )

  // last one
  nds[M-1].co[0] = co[M-1];
  nds[M-1].co[1].a = tielo1.Y;
  // nds[M-1].co[1].r = xor.A;
  xor1.A = reset_nor.Y;
  nds[M-1].co[1].r = inv_loop.A;
  ]
}

// Non-deterministic split for stable guards
export template <pint N>
defproc nds_split_stable (bool? gs[N]; a1of1? m1; a1of1 co[N]) 
{
  [ N=1  -> 
  
  co[0].a = m1.a;
  std::cells::LATCHLO latch_lo(.D=m1.r,.Q=co[0].r, .CLK=gs[0], .R=Reset);
  
  []else ->
  // No. of NDS blocks = (Selection_way - 1)
  pint M = N-1;

  bool _r0, r0;

  nds_two_way nds[M];
  std::cells::NOR2X1 nors[M];

  // first one
  nds[0].m1.a = m1.a;
  nds[0].m1.r = r0;

  // evaluation trigger
  prs * {
    ~m1.r -> _r0+
    m1.r & (|i : N : gs[i] ) -> _r0- 
    _r0 => r0-
  }

  // chain 'em
  ( i : M-1 : nds[i].co[0] = co[i]; 
              nds[i].co[1] = nds[i+1].m1; )

  // connect guards and inverted guards for all except last
  ( i : M-1 : nors[i].A = gs[i];
              nors[i].B = Reset;
              nors[i].Y = nds[i].gs[1];
              nds[i].gs[0] = gs[i]; )

  // last one
  nds[M-1].gs[0] = gs[M-1];
  nds[M-1].gs[1] = gs[M];
  nds[M-1].co[0] = co[M-1];
  nds[M-1].co[1] = co[M];
  ]
}

// ------------------------------------

// N-way loop construct ---------------
// Last (N-th) guard must be the 'else' 
// i.e. the case where the loop terminates
// 

template <pint N>
defproc loop_wrapper (bool? gs[N+1]; a1of1? m1; 
                      a1of1 spi[N]; a1of1 spo[N]; 
                      bool! delay_o; bool? delay_i; a1of1 p1)
{

  std::cells::AND2X1 ctrl_and; 
  std::gates::ctree<2, true> c;

  ctrl_and.A = m1.r;
  ctrl_and.B = c.out;
  ctrl_and.Y = delay_o;

  std::cells::AND2X1 ands[N+1];
  ( i : N+1 : ands[i].A = delay_i; )
  ( i : N+1 : ands[i].B = gs[i]; )
  ( i : N : ands[i].Y = spi[i].r; )
            ands[N].Y = p1.r;

  std::gates::ortree<N, false> or_spi;
  ( i : N: or_spi.in[i] = spi[i].a; )

  std::gates::ortree<N, false> or_spo;
  ( i : N: or_spo.in[i] = spo[i].r; )
  ( i : N: or_spo.out   = spo[i].a; )

  c.in[0] = or_spi.out;
  c.in[1] = or_spo.out;

  p1.a = m1.a;
}

// ------------------------------------

// Do-loop construct ------------------
// Only one guard allowed

defproc doloop_wrapper (bool? g; a1of1? m1; 
                        a1of1 spi; a1of1 spo; 
                        bool! delay_o; bool? delay_i; a1of1 p1) 
{

  std::cells::AND2X1 ctrl_and; 
  std::gates::ctree<2, true> c;

  ctrl_and.A = m1.r;
  ctrl_and.B = c.out;
  ctrl_and.Y = spi.r;

  std::cells::AND2X1 ands[2];
  std::cells::INVX1 inv_g;
  inv_g.A = g;

  spo.r = delay_o;

  ands[0].A = g;        ands[0].B = delay_i;  
  ands[1].A = inv_g.Y;  ands[1].B = delay_i;

  ands[0].Y = c.in[0];  
  ands[0].Y = spo.a;
  c.in[1]   = spi.a;

  ands[1].Y = p1.r;

  p1.a = m1.a;
}
// ------------------------------------


// N : No. of inputs, W : Width of each input
export template<pint N,W>
defproc merge_mux_old_1(bool? c[N]; bool? din[N][W]; bool! dout[W]; bool a)
{
  { N>1 : "Size two or greater merge mux only"};
  
  std::gates::xortree<N, false> xort(c);
  delay_line<R2P_MERGE_MUX_DELAY> delay_xor;
  delay_xor.in = xort.out;
  
  // last-changed detector (one-hot output) circuit ---
  bool new_c[N];
  std::cells::XOR2X1 xors[N];
  
  capture_init<R2P_MERGE_MUX_CD,R2P_MERGE_MUX_PW,1,0> capt1[N], capt2[N];

  ( i : N :
    capt1[i].din[0] = c[i];
    capt1[i].dout[0] = xors[i].A;
    capt1[i].din[0]  = xors[i].B;
    capt2[i].din[0]  = xors[i].Y;
    capt2[i].dout[0] = new_c[i];
    capt2[i].go.r = delay_xor.out;
    capt2[i].go.a = capt1[i].go.r; 
   )
  // last-changed detector (one-hot output) circuit ---

  // aoi's
  std::cells::AOI22X1 stage_1[N/2][W];
  [ (N%2)=1 -> std::cells::NAND2X1 last[W]; ]
  
  sigbuf<W> fanout_tree[N];
  ( i : N : fanout_tree[i].in = new_c[i]; )

  ( i : N/2 : ( j : W : stage_1[i][j].A = din[ 2*i   ][j];        
                        stage_1[i][j].C = din[(2*i)+1][j]; ) ) 

  ( i : N/2 : ( j : W : stage_1[i][j].B = fanout_tree[ 2*i   ].out[j];
                        stage_1[i][j].D = fanout_tree[(2*i)+1].out[j]; ) )

  [ (N%2)=1 -> ( j : W : last[j].A = din[N-1][j];
                         last[j].B = fanout_tree[N-1].out[j]; ) 
  ]

  // nands
  std::gates::andtree<(N+1)/2, true> stage_2[W]; 

  ( i : N/2 :  ( j : W : stage_1[i][j].Y = stage_2[j].in[i]; ) )
  [ (N%2)=1 -> ( j : W :       last[j].Y = stage_2[j].in[(N-1)/2]; ) 
  ]

  ( j : W : stage_2[j].out = dout[j]; ) 
}

export template<pint N,W>
defproc merge_mux_ohc_opt(bool? c[N]; bool din[N][W]; bool dout[W]; bool a)
{
  { N>0 : "Size one or greater merge mux only"};
  [N=1 -> din[0][0..W-1] = dout[0..W-1];
  []else ->
  
  std::gates::xortree<N, false> xort(c);
  delay_line<R2P_MERGE_MUX_DELAY> delay_xor;
  delay_xor.in = xort.out;
  
  // last-changed detector (one-hot output) circuit ---
  bool new_c[N];
  std::cells::XOR2X1 xors[N];
  
  capture_init<R2P_MERGE_MUX_CD,R2P_MERGE_MUX_PW,1,0> capt1[N], capt2[N];

  ( i : N :
    capt1[i].din[0] = c[i];
    capt1[i].dout[0] = xors[i].A;
    capt1[i].din[0]  = xors[i].B;
    capt2[i].din[0]  = xors[i].Y;
    capt2[i].dout[0] = new_c[i];
    capt2[i].go.r = delay_xor.out;
    capt2[i].go.a = capt1[i].go.r; 
  )
  // last-changed detector (one-hot output) circuit ---

  std::cells::TBUF1 tb[N][W];
  std::cells::INVX1 invs[W];

  sigbuf<W> fanout_tree[N];
  ( i : N : fanout_tree[i].in = new_c[i]; )

  ( i : N : 
    ( j : W : 
      tb[i][j].EN = fanout_tree[i].out[j];
      tb[i][j].A  = din[i][j];
      tb[i][j].Y  = invs[j].A;
      dout[j] = invs[j].Y;
    )
  )
  ]
}


export defproc capture_bool_ext (bool i; bool dout[1])
{
  i = dout[0];
}


// Custom Circuit Implementations for Small Programs


/*
 *    Implementation of *[ L?x; R!f(x) ]
 *    LW : L-chan width
 *    RW : R-chan width
 *    CD : Capture delay
 *    PW : Pulse width for latch
 */

export template <pint LW, RW, CD, PW>
defproc fblock_impl (ring_chan<LW> L; ring_chan<RW> R; bool ei[LW]; bool eo[RW]; a1of1 d_in; a1of1 d_out)
{
  elem_c_ppa block_1;
  connect_inchan_to_ctrl<LW> conn_z_2;
  conn_z_2.ctrl = block_1.zero;
  conn_z_2.ch = L;

  capture<CD,PW,LW> latch_x_0;
  latch_x_0.go = block_1.data;
  [ LW > 0 -> latch_x_0.din = L.d; ]
  latch_x_0.tx.a = L.a;

  prs * {
    block_1.m1.a => block_1.m1.r-
  }

  connect_outchan_to_ctrl<RW> conn_z_3;
  conn_z_3.ch = R;

  [ LW > 0 -> var_access<LW> va_blk_1(latch_x_0.dout,ei); ]
  [ RW > 0 -> connect_exprblk_dout<RW> conn_out_2(eo,conn_z_3.e); ]

  d_in = block_1.p1;
  d_out = conn_z_3.ctrl;
}

/*
 *    Implementation of *[ R!k ]
 *    RW : R-chan width
 *    K  : Constant-value
 */
export template <pint RW, K>
defproc const_src_impl (ring_chan<RW> R)
{

  { K >= 0 : "Only non-negative values in const-source" };
  { RW=0 | (K <= (1<<RW)-1) : "Const. value out of bounds" };

  std::cells::NOR2X1 ctrl;
  ctrl.A = Reset;
  ctrl.B = R.a;
  ctrl.Y = R.r;

  pint ival = K;
  pint j = 0;

  *[ j < RW -> [ (ival%2) = 0 -> std::cells::TIELOX1 x_lo[j..j];                         
                                x_lo[j].Y = R.d[j];

             [] (ival%2) = 1 -> std::cells::TIEHIX1 x_hi[j..j];                         
                                x_hi[j].Y = R.d[j];

              ]; j = j + 1; ival = ival >> 1;
  ]

  spec {
    timing ctrl.B- -> ctrl.Y+
    timing ctrl.B+ -> ctrl.Y-
  }
}

/*
 *    Implementation of *[ L?x ]
 *    LW : L-chan width
 *    LATCH : Whether to latch value 
 *            L?x -> true
 *            L?  -> false
 */
export template <pint LW, CD, PW; pbool LATCH>
defproc snk_impl (ring_chan<LW> L)
{
  [ LATCH & LW>0 ->  
              capture<CD, PW, LW> capt;
              capt.go.r = L.r;
              capt.go.a = L.a;
              capt.din = L.d;

  [] else -> L.r = L.a;
  ]
}

  }

}

