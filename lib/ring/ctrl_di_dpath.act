// CMOS implementable versions of the pipeline elements
// QDI Datapath

import "syn/qdi/_all_.act";

namespace syn {
  
  export namespace ring_di_dpath {
    

// Data and Channel Types ---------------------------------

export template<pint W> 
deftype ring_int <: int<W> (bool t[W]; bool f[W]) {}

export template<pint W>
defchan ring_chan <: chan(int<W>) (ring_int<W> d; bool a; bool r) {}

export template<pint W>
defchan ring_expr_chan <: chan(int<W>) (ring_int<W> d; bool r) {}

// --------------------------------------------------------


// Compatibility Layer ------------------------------------

export template<pint W>
defproc exprchan_match_t (sdtexprchan<W> s; ring_expr_chan<W> r)
{
  r.r = s.r;
  ( i : W :
      r.d.t[i] = s.d.d[i].t;
      r.d.f[i] = s.d.d[i].f; )
}

export template<pint W, N>
defproc exprchan_match (sdtexprchan<W> s[N]; ring_expr_chan<W> r[N])
{
  exprchan_match_t<W> e[N];
  ( i : N : 
      e[i].s = s[i]; 
      e[i].r = r[i]; )
}

// --------------------------------------------------------

template<pbool I>
defcell reg_one_bit(bool? wt, wf; bool! dt, df; bool? Reset) {
  prs * {
    /* write port */
    wf<8> -> dt-
    wt<8> -> df-

    /* hold state */
    [iskeeper=1] df<8> -> dt-
    [iskeeper=1] dt<8> -> df-
    [weak=1] ~dt<4, 4> -> df+
    [weak=1] ~df<4, 4> -> dt+
  }
  [  I    -> prs { Reset -> df- }
  [] else -> prs { Reset -> dt- }
  ]
}

export template<pint W; pbool I>
defproc register (ring_int<W> v; bool? wt[W], wf[W]) {
  reg_one_bit<I> bits[W];
  ( i : W:
    bits[i](wt[i], wf[i], v.t[i], v.f[i], Reset);
  )
}

export template<pint W; pint V>
defproc register_init (ring_int<W> v; bool? wt[W], wf[W]) {

  { V >= 0 : "Only non-negative initial values" };
  { V <= (1<<W)-1 : "Initial value out of bounds" };

  pint ival = V;
  pint j = 0;

  *[ j < W -> [ (ival%2) = 0 -> reg_one_bit<false> bits_lo[j..j];
                                bits_lo[j].wt = wt[j]; 
                                bits_lo[j].wf = wf[j];
                                bits_lo[j].dt = v.t[j];
                                bits_lo[j].df = v.f[j];
                                bits_lo[j].Reset = Reset; 

             [] (ival%2) = 1 -> reg_one_bit<true> bits_hi[j..j];
                                bits_hi[j].wt = wt[j]; 
                                bits_hi[j].wf = wf[j];
                                bits_hi[j].dt = v.t[j];
                                bits_hi[j].df = v.f[j];
                                bits_hi[j].Reset = Reset; 

              ]; j = j + 1; ival = ival >> 1;
  ]
}

// Basic Elements -----------------------------------------

defproc inverter (bool? in; bool! out)
{
    prs{
        in => out-
    }
    sizing { 
        out{-1} 
    }
}

// --------------------------------------------------------


template <pint W>
defproc gen_req (ring_chan<W> C; bool r)
{
  std::gates::ctree<W, false> c;
  std::cells::OR2X1 ors[W];
  ( i : W : 
      ors[i].A = C.d.t[i];
      ors[i].B = C.d.f[i];
      ors[i].Y = c.in[i];
   )
  
  c.out = r;
}

// Connectors ---------------------------------------------

export defproc gp_connect (a1of1 m1; a1of1 p1)
{
  m1 = p1;
}

export template<pint W>
defproc connect_inchan_to_ctrl (ring_chan<W> ch; a1of1 ctrl)
{
  gen_req<W> g(ch, ctrl.r);
  ctrl.a = ch.a;
}

export template<pint W>
defproc connect_outchan_to_ctrl (ring_chan<W> ch; a1of1 ctrl; ring_expr_chan<W> e)
{
  ctrl.r = e.r;
  e.d = ch.d;
  ch.a = ctrl.a;
}

export template<pint W>
defproc wrap_to_array(ring_expr_chan<W> in; ring_expr_chan<1> out[W]) {
  ( i : W:
    in.r = out[i].r;
    in.d.t[i] = out[i].d.t[0];
    in.d.f[i] = out[i].d.f[0];
  )
}

export template<pint W>
defproc wrap_from_array(ring_expr_chan<1> in[W]; ring_expr_chan<W> out) {
  ( i : W :
    out.r = in[i].r;
    out.d.t[i] = in[i].d.t[0];
    out.d.f[i] = in[i].d.f[0];
  )
}

// FLAG: connects to expr block
export template<pint W>
defproc connect_exprblk_dout (sdtexprchan<1> d[W]; ring_expr_chan<W> ch)
{
  ring_expr_chan<1> dr[W];
  exprchan_match<1,W> em(d,dr);

  wrap_from_array<W> conv;
  conv.in = dr;
  conv.out = ch;
}

// FLAG: connects to expr block
export template<pint W>
defproc connect_exprblk_assign (sdtexprchan<1> e[W]; ring_int<W> d; a1of1 tx)
{
  ring_expr_chan<1> er[W];
  exprchan_match<1,W> em(e,er);

  ring_expr_chan<W> ch;
  wrap_from_array<W> conv;
  conv.in = er;
  conv.out = ch;

  d = ch.d;
  tx.r = ch.r;
}

// --------------------------------------------------------

// QDI Datapath Elements -------------------------

export template<pint W>
defproc mywriteport(bool wt[W], wf[W]; a1of1 go; ring_int<W> in; ring_int<W> reg)
{
  bool _wt[W];
  bool _wf[W];
  bool _wack[W];

  prs {

    // ( i : W : ~go.r & ~in.t[i]  -> _wt[i]+ )
    ( i : W : ~go.r  -> _wt[i]+ )
    // ( i : W : ~go.r & ~in.f[i]  -> _wf[i]+ )
    ( i : W : ~go.r  -> _wf[i]+ )
    ( i : W :  go.r &  in.t[i]  -> _wt[i]- )
    ( i : W :  go.r &  in.f[i]  -> _wf[i]- )

    ( i : W : _wt[i] => wt[i]- )
    ( i : W : _wf[i] => wf[i]- )

    ( i : W : (wt[i] & reg.t[i]) | (wf[i] & reg.f[i]) -> _wack[i]- )
    ( i : W : ~wt[i] & ~wf[i] -> _wack[i]+ )
  }
  
  std::gates::ctree<W, false> wa(_wack);
  
  prs {
    Reset | wa.out => go.a-
  }
}

export template<pint W>
defproc myreadport(ring_int<W> var; ring_expr_chan<W> out) 
{
  bool xout;
  std::gates::sigbuf<W> s(xout);

  prs {
    out.r => xout-

    ( i : W :
      ~s.out[i] & ~var.t[i] -> out.d.f[i]+
      ~s.out[i] & ~var.f[i] -> out.d.t[i]+
      s.out[i] -> out.d.f[i]-
      s.out[i] -> out.d.t[i]- )
  }
}

// single rail readport to only get true-rail of latched guards
export defproc myreadport_sr(ring_int<1> var; bool r; bool d) 
{
  bool xout;

  prs {
    r => xout-
    ~xout & ~var.f[0] -> d+
     xout -> d- 
  }
}

defproc two_to_four_brs (a1of1 in; a1of1 out)
{
    bool x, _out_r, _Reset;
    prs {

        Reset => _Reset-

        _Reset & in.r & out.a -> x-
       ~_Reset | (~in.r & ~out.a) -> x+

        _Reset & in.r & x -> _out_r-
        ~_Reset | ~x -> _out_r+

        _out_r => out.r-

        x -> in.a-
        ~x & ~out.a -> in.a+
    }
}

export template <pint CD, PW, W>
defproc capture(a1of1 go; ring_int<W> din; ring_int<W> dout; a1of1 tx)
{
  register<W,false> reg;
  reg.v = dout;
  
  mywriteport<W> wp;
  wp.wt = reg.wt;
  wp.wf = reg.wf;
  wp.reg = reg.v;
  wp.in = din;

  two_to_four_brs tf;
  go = tf.in;
  wp.go = tf.out;
  tf.out.r = tx.r;
}

export template <pint CD, PW, W>
defproc capture_dummy(a1of1 go; ring_int<W> din; ring_int<W> dout; a1of1 tx)
{
  register<W,false> reg;
  reg.v = dout;
  
  mywriteport<W> wp;
  wp.wt = reg.wt;
  wp.wf = reg.wf;
  wp.reg = reg.v;
  wp.in = din;

  two_to_four_brs tf;
  go = tf.in;
  wp.go = tf.out;
  tf.out.r = tx.r;
}

// FLAG: connects to expr block
export template <pint W>
defproc var_access(ring_int<W> din; sdtexprchan<1> dout[W])
{
  ring_expr_chan<1> doutr[W];
  exprchan_match<1,W> em(dout,doutr);
  myreadport<W> read;
  din = read.var;

  wrap_to_array<W> conv;
  conv.in = read.out;
  conv.out = doutr;
  
}

export template <pint CD, PW, W, INIT_VAL>
defproc capture_init_new_k(a1of1 go; a1of1 go2; ring_int<W> din; ring_int<W> dout; a1of1 tx)
{
}

export template <pint CD, PW, W, INIT_VAL>
defproc capture_init_new(a1of1 go; a1of1 go2; ring_int<W> din; ring_int<W> dout; a1of1 tx)
{
  register_init<W,INIT_VAL> reg;
  reg.v = dout;
  
  mywriteport<W> wp;
  wp.wt = reg.wt;
  wp.wf = reg.wf;
  wp.reg = reg.v;
  wp.in = din;

  two_to_four_brs tf;
  go = tf.in;
  wp.go = tf.out;
  tf.out.r = tx.r;

  go2.a = go2.r;
  wp.in = din;
  reg.v = dout;
}

export template <pint CD, PW, W, INIT_VAL>
defproc capture_init_new_2(a1of1 go; a1of1 go2; ring_int<W> din; ring_int<W> dout; a1of1 tx)
{
  connect_exprblk_assign<W> conn;

  two_to_four_brs tf1, tf2;
  tf1.in = go;
  tf2.in = go2;

  register<W,false> reg1;
  register<W,false> reg2;
  reg2.v = dout;
  
  mywriteport<W> wp1, wp2;
  wp1.wt = reg1.wt;
  wp1.wf = reg1.wf;
  wp1.reg = reg1.v;
  tf1.out = wp1.go;
  tf1.out = tx;

  wp2.wt = reg2.wt;
  wp2.wf = reg2.wf;
  wp2.reg = reg2.v;
  tf2.out = wp2.go;
  tf2.out = conn.tx;

  var_access<W> vax;
  vax.din = reg1.v;
  vax.dout = conn.e;
  conn.d = reg2.v;

  wp1.in = din;
  reg2.v = dout;
}

export template <pint W>
defproc var_access_2(ring_int<W> din; ring_expr_chan<W> dout)
{
  myreadport<W> read;
  din = read.var;

}

export defproc var_access_sr(ring_int<1> din; bool r; bool d)
{
  myreadport_sr read;
  din = read.var;
  r   = read.r;
  d   = read.d;
}

export template<pint W>
defproc chan_access(ring_chan<W> C; ring_int<W> dout)
{
  C.d = dout;
}

export template<pint W>
defproc probe_access(ring_chan<W> C; ring_expr_chan<1> dout[1])
{
  bool _t, _f;
  prs {
    dout[0].r & C.d.t[0] -> _t-
    ~dout[0].r -> _t+
    dout[0].r & C.d.f[0] -> _f-
    ~dout[0].r -> _f+

    _f => dout[0].d.f[0]-
    _t => dout[0].d.t[0]-
  }
}

export
defproc dummy_probe_clause(bool? g[1]; bool! out[1]) {
  { false : "wip" }; 
  out = g;
}

