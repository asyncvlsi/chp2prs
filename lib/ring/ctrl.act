export defproc capture_bool (bool i; bool dout[1])
{
  i = dout[0];
}


// Variables and Channels ---------------------------------

export template <pint M>
deftype ring_int <: int<M> (bool d[M]) {} 

export defchan ring_chan <: bd () {}

// --------------------------------------------------------

// Custom Circuit Implementations for Small Programs


/*
 *    Implementation of *[ L?x; R!f(x) ]
 *    LW : L-chan width
 *    RW : R-chan width
 *    CD : Capture delay
 *    PW : Pulse width for latch
 */

export template <pint LW, RW, CD, PW>
defproc fblock_impl (ring_chan<LW> L; ring_chan<RW> R; bool ei[LW]; bool eo[RW]; a1of1 d_in; a1of1 d_out)
{
  elem_c_ppa block_1;
  connect_inchan_to_ctrl<LW> conn_z_2;
  conn_z_2.ctrl = block_1.zero;
  conn_z_2.ch = L;

  capture<CD,PW,LW> latch_x_0;
  latch_x_0.go = block_1.data;
  latch_x_0.din = L.d;
  latch_x_0.tx.a = L.a;

  prs {
    block_1.m1.a => block_1.m1.r-
  }

  connect_outchan_to_ctrl<RW> conn_z_3;
  conn_z_3.ch = R;

  var_access<LW> va_blk_1(latch_x_0.dout,ei);
  connect_exprblk_dout<RW> conn_out_2(eo,conn_z_3.e);

  d_in = block_1.p1;
  d_out = conn_z_3.ctrl;
}

/*
 *    Implementation of *[ R!k ]
 *    RW : R-chan width
 *    K  : Constant-value
 */
export template <pint RW, K>
defproc const_src_impl (ring_chan<RW> R)
{

  { K >= 0 : "Only non-negative values in const-source" };
  { K <= (1<<RW)-1 : "Const. value out of bounds" };

  std::cells::NOR2X1 ctrl;
  ctrl.A = Reset;
  ctrl.B = R.a;
  ctrl.Y = R.r;

  pint ival = K;
  pint j = 0;

  *[ j < RW -> [ (ival%2) = 0 -> std::cells::TIELOX1 x_lo[j..j];                         
                                x_lo[j].Y = R.d[j];

             [] (ival%2) = 1 -> std::cells::TIEHIX1 x_hi[j..j];                         
                                x_hi[j].Y = R.d[j];

              ]; j = j + 1; ival = ival >> 1;
  ]
}

/*
 *    Implementation of *[ L?x ]
 *    LW : L-chan width
 *    LATCH : Whether to latch value 
 *            L?x -> true
 *            L?  -> false
 */
export template <pint LW, CD, PW; pbool LATCH>
defproc snk_impl (ring_chan<LW> L)
{
  [ LATCH ->  capture<CD, PW, LW> capt;
              capt.go.r = L.r;
              capt.go.a = L.a;
              capt.din = L.d;

  [] else -> L.r = L.a;
  ]
}

  }

}

