export defproc elem_c_paa_shared (a1of1 m1; a1of1 zero; a1of1 p1)
{
    inverter im1r, izeroa;
    im1r.in = m1.r;
    izeroa.in = zero.a;

    asym_c_brs ac;
    ac.A = im1r.out;
    ac.B = zero.a;
    ac.C = m1.a;
    ac.Y = zero.r;

    bool pre_p1r, _p1r, _p1a;

    m1.a = pre_p1r;

    prs {
        ~Reset & ( ~im1r.out & ~izeroa.out ) -> pre_p1r+
         Reset | (  im1r.out &  izeroa.out ) -> pre_p1r-

         Reset | (~pre_p1r               & ~_p1a) -> _p1r+
        ~Reset & ( pre_p1r &  izeroa.out &  _p1a) -> _p1r-
         _p1r => p1.r-
         p1.a => _p1a-
    }
}
